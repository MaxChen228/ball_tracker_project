#!/usr/bin/env bash
# Shared pre-push gate — keep `main` green in two-person collaboration.
#
# Install once per clone:
#     git config core.hooksPath scripts/hooks
#
# What it does (only runs what the push actually touches):
#   - server/*.py changed   → cd server && uv run pytest
#   - *.swift changed       → xcodebuild build-for-testing
#                             (compiles the TEST target — the exact gap that
#                              `xcodebuild build` on a simulator misses)
#
# Bypass (use sparingly, you own the consequence on main):
#     git push --no-verify            # skip everything
#     BALL_TRACKER_SKIP_IOS=1 git push   # skip only the slow iOS build
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
ZERO=0000000000000000000000000000000000000000
changed=""

while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue            # branch deletion — nothing to test
  if [ "$remote_sha" = "$ZERO" ]; then              # new branch on remote
    base="$(git merge-base origin/main "$local_sha" 2>/dev/null || true)"
    range="${base:+$base..}$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi
  changed+="$(git diff --name-only "$range" 2>/dev/null || true)"$'\n'
done

echo "$changed" | grep -q . || exit 0               # nothing to push

need_py=0; need_ios=0
echo "$changed" | grep -qE '^server/.*\.py$'                 && need_py=1
echo "$changed" | grep -qE '\.swift$'                        && need_ios=1

if [ "$need_py" = 1 ]; then
  echo "▶ pre-push: server pytest…"
  ( cd "$ROOT/server" && uv run pytest -q ) \
    || { echo "✗ pytest 失敗 — push 擋下（繞過：git push --no-verify）"; exit 1; }
fi

if [ "$need_ios" = 1 ]; then
  if [ "${BALL_TRACKER_SKIP_IOS:-0}" = 1 ]; then
    echo "⏭ pre-push: 跳過 iOS build（BALL_TRACKER_SKIP_IOS=1）"
  else
    echo "▶ pre-push: iOS build-for-testing（含 test target 編譯）…"
    ( cd "$ROOT" && xcodebuild \
        -project ball_tracker.xcodeproj -scheme ball_tracker \
        -sdk iphonesimulator \
        -destination 'platform=iOS Simulator,name=iPhone 17,OS=26.4' \
        build-for-testing -quiet ) \
      || { echo "✗ iOS build 失敗 — push 擋下（繞過：BALL_TRACKER_SKIP_IOS=1 或 git push --no-verify）"; exit 1; }
  fi
fi

echo "✓ pre-push 檢查通過"
